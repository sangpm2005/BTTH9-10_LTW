@model IEnumerable<BaiTH9.Models.Sach>

@{
    ViewBag.Title = "HTSachTheoChuDe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="section-title">Sách Theo Chủ Đề</h2>

@if (Model == null || !Model.Any())
{
    <p style="color:red; font-style:italic;">Không có sách thuộc chủ đề này.</p>
}
else
{
    <div class="card-container">
        @foreach (var s in Model)
        {
            <div class="card">
                <div class="card-img-container">
                    <img src="~/Content/HinhAnhSP/@s.AnhBia" alt="@s.TenSach" class="card-img" />
                </div>
                <div class="card-content">
                    <h3 class="card-title">@s.TenSach</h3>
                    <p class="card-text">@s.MoTa</p>
                    <a href="@Url.Action("Details", "BaiTH9", new { id = s.MaSach })" class="card-button">
                        Xem Chi Tiết
                    </a>
                </div>
            </div>
        }
    </div>
}


