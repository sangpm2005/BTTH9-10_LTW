<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fahasa.com</title>
    <link rel="stylesheet" href="~/Content/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="~/Script/js/script.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</head>
<body>
    <!-- Header Section -->
    <header>
        <div class="container">
            <div class="header-content">
                <div class="logo">Fahasa.com</div>
                <nav>
                    <ul>
                        <li><a href="@Url.Action("Index","BaiTH9")" onclick="showPage('home')">Trang Chủ</a></li>
                        <li><a href="#" onclick="showPage('home')">Giới Thiệu</a></li>
                        <li><a href="#" onclick="showPage('home')">Dịch Vụ</a></li>
                        <li><a href="#" onclick="showPage('home')">Sản Phẩm</a></li>
                        <li><a href="#" onclick="showPage('home')">Liên Hệ</a></li>
                        <li><a href="@Url.Action("Login","BaiTH9")" class="btn btn-login">Đăng nhập</a></li>
                        <li><a href="@Url.Action("Register","BaiTH9")" class="btn btn-register">Đăng ký ngay</a></li>
                    </ul>
                </nav>
            </div>
        </div>
    </header>

    <!-- Main Content Section -->
    <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-3">
                    <h1 class="bg-success large"> CHU DE </h1>
                    @Html.Action("DSMenu_ChuDe", "BaiTH9")

                    <h1 class="bg-success large"> NHA XUAT BAN </h1>
                    @Html.Action("DSMenu_NXB", "BaiTH9")
                </div>

                <div class="col-md-9">
                    <div>
                        @RenderBody()
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer Section -->
    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Thông Tin Liên Hệ</h3>
                    <p>Địa chỉ: 123 Đường ABC, Quận XYZ, TP. Hồ Chí Minh</p>
                    <p>Điện thoại: (0123) 456-789</p>
                    <p>Email: contact@example.com</p>
                </div>
                <div class="footer-section">
                    <h3>Liên Kết Nhanh</h3>
                    <a href="#">Trang Chủ</a>
                    <a href="#">Giới Thiệu</a>
                    <a href="#">Dịch Vụ</a>
                    <a href="#">Sản Phẩm</a>
                </div>
                <div class="footer-section">
                    <h3>Theo Dõi Chúng Tôi</h3>
                    <a href="#">Facebook</a>
                    <a href="#">Twitter</a>
                    <a href="#">Instagram</a>
                    <a href="#">LinkedIn</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2023 Tên Công Ty. Tất cả các quyền được bảo lưu. | Phát triển bởi Nhóm Phát Triển</p>
            </div>
        </div>
    </footer>
</body>
</html>

