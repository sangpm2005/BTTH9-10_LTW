@model BaiTH10.Models.GioHang
@{
    ViewBag.Title = "XemGioHang";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <h2 class="section-title">Thông tin giỏ hàng đã chọn</h2>
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th> Mã Sản Phẩm</th>
                    <th> Tên Sản Phẩm</th>
                    <th> Ảnh</th>
                    <th> Số lượng</th>
                    <th> Đơn giá</th>
                    <th> Thành Tiền</th>
                    <th></th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var item in Model.lst)
                {
                    <tr>
                        <td>@item.iMaSach</td>
                        <td>@item.sTenSach</td>
                        <td>@item.sAnhBia</td>
                        <td>@item.iSoLuong</td>
                        <td>@item.dDonGia</td>
                        <td>@item.ThanhTien</td>
                        <td> <a href="#"> Chi tiết sách</a></td>
                        <td> <a href="#"> Xóa</a></td>
                        <td> <a href="#" class="btn-edit"> Sửa</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

