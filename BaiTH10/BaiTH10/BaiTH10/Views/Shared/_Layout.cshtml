<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopping Online</title>
    <link rel="stylesheet" href="~/Content/css/style.css">
    <script src="~/Scripts/js/script.js" defer></script>
</head>
<body>
    <!-- Header Section -->
    <header>
        <div class="container">
            <div class="header-content">
                <div class="logo">Logo Website</div>
                <nav>
                    <ul>
                        <li><a href="#" onclick="showPage('home')">Trang Chủ</a></li>
                        <li><a href="#" onclick="showPage('home')">Giới Thiệu</a></li>
                        <li><a href="#" onclick="showPage('home')">Dịch Vụ</a></li>
                        <li><a href="@Url.Action("XemGioHang","BaiTH10")" onclick="showPage('home')">Giỏ Hàng</a></li>
                        <li><a href="#" onclick="showPage('home')">Liên Hệ</a></li>
                    </ul>
                </nav>
                @if (Session["TenKH"] != null)
                {
                    <div>
                        Xin chào, <strong>@Session["TenKH"]</strong>!
                        <a href="@Url.Action("Logout", "BaiTH10")" class="btn btn-login">Đăng xuất</a>
                    </div>
                }

            </div>
        </div>
    </header>

    <!-- Main Content Section -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer Section -->
    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Thông Tin Liên Hệ</h3>
                    <p>Địa chỉ: 123 Đường ABC, Quận XYZ, TP. Hồ Chí Minh</p>
                    <p>Điện thoại: (0123) 456-789</p>
                    <p>Email: contact@example.com</p>
                </div>
                <div class="footer-section">
                    <h3>Liên Kết Nhanh</h3>
                    <a href="#">Trang Chủ</a>
                    <a href="#">Giới Thiệu</a>
                    <a href="#">Dịch Vụ</a>
                    <a href="#">Sản Phẩm</a>
                </div>
                <div class="footer-section">
                    <h3>Theo Dõi Chúng Tôi</h3>
                    <a href="#">Facebook</a>
                    <a href="#">Twitter</a>
                    <a href="#">Instagram</a>
                    <a href="#">LinkedIn</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2023 Tên Công Ty. Tất cả các quyền được bảo lưu. | Phát triển bởi Nhóm Phát Triển</p>
            </div>
        </div>
    </footer>
</body>
</html>